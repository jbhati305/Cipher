CIPHER_APP_NAME=Cipher
CIPHER_APP_VERSION=0.1.0
CIPHER_ENVIRONMENT=development
CIPHER_DEBUG=true
CIPHER_LOG_LEVEL=INFO
CIPHER_DEFAULT_TIMEZONE=Asia/Kolkata
CIPHER_REMINDER_SCHEDULER_POLL_SECONDS=30
CIPHER_REMINDER_SCHEDULER_LOOKAHEAD_MINUTES=60
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4-nano
LLM_MAX_OUTPUT_TOKENS=220
LLM_MAX_CONTEXT_ITEMS=12
LLM_NOTE_CHAR_LIMIT=180
LLM_TIMEOUT_SECONDS=20
LLM_REASONING_EFFORT=none
LLM_VERBOSITY=low
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

GOOGLE_CALENDAR_CLIENT_ID=your_google_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALENDAR_TOKEN_FILE=.secrets/google-calendar-token.json
GOOGLE_CALENDAR_ID=primary

NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change_me
NEO4J_DATABASE=neo4j
NEO4J_VERIFY_CONNECTIVITY=true
ALLOW_DEGRADED_STARTUP=true
