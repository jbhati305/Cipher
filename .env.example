CIPHER_APP_NAME=Cipher
CIPHER_APP_VERSION=0.2.0
CIPHER_ENVIRONMENT=development
CIPHER_DEBUG=true
CIPHER_LOG_LEVEL=INFO
CIPHER_DEFAULT_TIMEZONE=Asia/Kolkata
CIPHER_API_HOST=127.0.0.1
CIPHER_API_PORT=8181
CIPHER_AUTH_REQUIRED=true
CIPHER_ADMIN_TOKEN=change-admin-token
CIPHER_HERMES_TOKEN=change-hermes-token
CIPHER_ALEXA_TOKEN=change-alexa-token
CIPHER_DATA_DIR=./data
CIPHER_EXPORTS_DIR=./data/exports
CIPHER_SQLITE_PATH=./data/cipher.sqlite3
CIPHER_MODEL_ROUTING_POLICY_FILE=config/model-routing.yaml

LLM_PROVIDER=nvidia_nim
LLM_MODEL=nvidia/nemotron-3-ultra-550b-a55b
NVIDIA_API_KEY=nvapi-your-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
OLLAMA_BASE_URL=http://localhost:11434
LLM_MAX_OUTPUT_TOKENS=512
LLM_TIMEOUT_SECONDS=30

# Optional hosted model providers.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

MEMOS_BASE_URL=http://localhost:8000
MEMOS_USER_ID=root
MEMOS_MEM_CUBE_ID=cipher
MEMOS_TIMEOUT_SECONDS=10
QDRANT_URL=http://localhost:6333

GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_TOKEN_FILE=.secrets/google-calendar-token.json
GOOGLE_CALENDAR_ID=primary

NOTION_API_KEY=
NOTION_PAPERS_DATABASE_ID=

ALLOW_DEGRADED_STARTUP=true
